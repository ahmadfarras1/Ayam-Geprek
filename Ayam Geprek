#include <stdio.h>
#include <string.h>

#define MAX 100000

// Stack (ONLINE)
int stack[MAX];
int top = -1;

// Queue (OFFLINE) 
int queue[MAX];
int frontQ = 0, rearQ = -1;

// Dequeue (P_ONLINE) 
int deque[MAX];
int frontD = 0, rearD = -1;

int main() {
    int n;
    scanf("%d", &n);

    char cmd[20];
    int x;
    int rush = 0;

    for (int i = 0; i < n; i++) {
        scanf("%s", cmd);

        if (strcmp(cmd, "OFFLINE") == 0) {
            scanf("%d", &x);
            queue[++rearQ] = x;
        }
        else if (strcmp(cmd, "ONLINE") == 0) {
            scanf("%d", &x);
            stack[++top] = x;
        }
        else if (strcmp(cmd, "P_ONLINE") == 0) {
            scanf("%d", &x);
            deque[++rearD] = x;
        }
        else if (strcmp(cmd, "RUSH") == 0) {
            rush = 1;
        }
        else if (strcmp(cmd, "SERVE") == 0) {

            int result = -1;

            // RUSH
            if (rush) {
                if (top != -1) {
                    result = stack[top--];
                }
                rush = 0;
            }

            // Normal priority
            if (result == -1 && frontD <= rearD) {
                result = deque[frontD++];
            }
            if (result == -1 && frontQ <= rearQ) {
                result = queue[frontQ++];
            }
            if (result == -1 && top != -1) {
                result = stack[top--];
            }

            if (result == -1) {
                printf("NO ORDERS\n");
            } else {
                printf("\n%d\n", result);
            }
        }
    }

    return 0;
}
